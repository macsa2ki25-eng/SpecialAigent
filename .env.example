# ==========================================
# Claude API (投稿文の生成に使用)
# https://console.anthropic.com/ でAPIキー発行
# ==========================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# 使用モデル。デフォルトは最新のSonnet。
# 最高品質: claude-opus-4-7 / 標準: claude-sonnet-4-6 / 最安: claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-6

# ==========================================
# X (旧Twitter) API - Pay Per Use
# https://developer.x.com/ でアプリ作成 → OAuth 1.0a の "Read and write" 権限
# ==========================================
X_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
X_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
X_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
X_ACCESS_TOKEN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 投稿するX上のユーザー名 (ログ用、@なし)
X_USERNAME=your_x_handle

# ==========================================
# はてなブログ AtomPub API (ブログ自動投稿)
# https://blog.hatena.ne.jp/-/config
# 設定 → 詳細設定 → AtomPub
# ==========================================
HATENA_USER_ID=your_hatena_id
HATENA_BLOG_DOMAIN=your_hatena_id.hatenablog.com
HATENA_API_KEY=xxxxxxxxxxxxxxxxxxxx

# ==========================================
# 楽天アフィリエイト + 楽天ウェブサービス
# アフィリエイトID: https://affiliate.rakuten.co.jp/
# アプリID: https://webservice.rakuten.co.jp/
# ==========================================
RAKUTEN_APPLICATION_ID=1234567890123456789
RAKUTEN_AFFILIATE_ID=00000000.00000000.00000000.00000000

# ==========================================
# Amazonアソシエイト (任意。後から追加でOK)
# https://affiliate.amazon.co.jp/
# ==========================================
AMAZON_ASSOCIATE_TAG=

# ==========================================
# 運用設定
# ==========================================
# 1日あたりの最大X投稿数 (商品アングル違いの複数投稿を含む)
MAX_POSTS_PER_DAY=5

# 1日あたりの最大ブログ投稿数 (SEO上、毎日1〜2本が上限目安)
MAX_BLOG_POSTS_PER_DAY=2

# 半自動モード (true=投稿前に人間承認 / false=即投稿)
REQUIRE_APPROVAL=true

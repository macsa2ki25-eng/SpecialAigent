# ==========================================
# Claude API (投稿文の生成に使用)
# https://console.anthropic.com/ でAPIキー発行
# ==========================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# 使用モデル。デフォルトは最新のSonnet。
# 最高品質を求めるならOpus、コスト重視ならHaiku。
ANTHROPIC_MODEL=claude-sonnet-4-6

# ==========================================
# X (Twitter) API v2 - Free tier
# https://developer.x.com/ でアプリ作成
# ==========================================
# Free tierで必要なのは以下4つ (OAuth 1.0a User Context)
X_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
X_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
X_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
X_ACCESS_TOKEN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# 運用設定
# ==========================================
# 1日あたりの最大投稿数 (Free tier 月500 = 1日16が上限)
MAX_POSTS_PER_DAY=10

# 半自動モード (true=投稿前に人間承認 / false=即投稿)
REQUIRE_APPROVAL=true

# 投稿するX上のユーザー名 (ログ用、@なし)
X_USERNAME=your_x_handle
